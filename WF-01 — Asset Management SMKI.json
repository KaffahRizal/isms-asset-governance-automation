    {
      "parameters": {
        "jsCode": "// Proses input aset baru dari webhook\nconst body = $input.first().json.body || $input.first().json;\n\n// Generate Asset ID otomatis\nconst now = new Date();\nconst assetId = 'AST-' + now.getFullYear() +\n  String(now.getMonth() + 1).padStart(2, '0') +\n  String(now.getDate()).padStart(2, '0') + '-' +\n  Math.floor(Math.random() * 9000 + 1000);\n\n// Tentukan klasifikasi berdasarkan tipe aset\nconst tipeAset = (body.tipe_aset || '').toLowerCase();\nlet klasifikasi = 'Internal';\nif (tipeAset.includes('server') || tipeAset.includes('database') || tipeAset.includes('data pelanggan')) {\n  klasifikasi = 'Confidential';\n} else if (tipeAset.includes('sistem') || tipeAset.includes('aplikasi')) {\n  klasifikasi = 'Restricted';\n} else if (tipeAset.includes('website') || tipeAset.includes('publik')) {\n  klasifikasi = 'Public';\n}\n\nreturn [{\n  json: {\n    asset_id: assetId,\n    nama_aset: body.nama_aset || '',\n    tipe_aset: body.tipe_aset || '',\n    klasifikasi: klasifikasi,\n    asset_owner: body.asset_owner || '',\n    departemen: body.departemen || '',\n    lokasi: body.lokasi || '',\n    nilai_aset: body.nilai_aset || 'Medium',\n    tanggal_registrasi: now.toISOString().split('T')[0],\n    tanggal_review_terakhir: now.toISOString().split('T')[0],\n    status_review: 'OK',\n    keterangan: body.keterangan || '',\n    dibuat_oleh: body.dibuat_oleh || 'System'\n  }\n}];"
      },
