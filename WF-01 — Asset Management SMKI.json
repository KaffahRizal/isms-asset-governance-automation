      "parameters": {
        "jsCode": "const assetData = $('Siapkan Data Aset Baru').first().json;\n\n// Ambil text dari LLM\nconst rawAi = $('Basic LLM Chain').first().json.text || '{}';\n\nlet parsedAi;\n\ntry {\n\n  // Bersihkan markdown jika ada\n  const cleaned = rawAi\n    .replace(/```json/g, '')\n    .replace(/```/g, '')\n    .trim();\n\n  parsedAi = JSON.parse(cleaned);\n\n} catch (error) {\n\n  parsedAi = {\n    risk_level: 'Unknown',\n    iso_controls: [],\n    reason: 'Failed to parse AI output'\n  };\n}\n\nreturn [\n  {\n    json: {\n\n      // DATA ASET\n      ...assetData,\n\n      // HASIL AI\n      'AI Risk Level':\n        parsedAi.risk_level || 'Unknown',\n\n      'AI ISO Controls':\n        Array.isArray(parsedAi.iso_controls)\n          ? parsedAi.iso_controls.join(', ')\n          : '',\n\n      'AI Reason':\n        parsedAi.reason || 'No reason'\n    }\n  }\n];"
      },
