      "parameters": {
        "jsCode": "// Generate laporan ringkasan bulanan inventory\nconst items = $input.all();\nconst today = new Date().toISOString().split('T')[0];\n\nlet total = items.length;\n\nlet overdue = 0;\nlet dueSoon = 0;\nlet ok = 0;\n\n// Statistik klasifikasi aset\nlet byKlasifikasi = {\n  Confidential: 0,\n  Restricted: 0,\n  Internal: 0,\n  Public: 0,\n  'Belum Diklasifikasi': 0\n};\n\n// Statistik AI Risk Level\nlet byRiskLevel = {\n  Critical: 0,\n  High: 0,\n  Medium: 0,\n  Low: 0,\n  Unknown: 0\n};\n\n// Counter ISO Controls\nlet isoControlCounter = {};\n\nfor (const item of items) {\n\n  const row = item.json;\n\n  // =========================\n  // STATUS REVIEW\n  // =========================\n  const status = row['Status Review'] || row.review_status;\n\n  if (status === 'OVERDUE') {\n    overdue++;\n  }\n  else if (status === 'DUE_SOON') {\n    dueSoon++;\n  }\n  else {\n    ok++;\n  }\n\n  // =========================\n  // KLASIFIKASI\n  // =========================\n  const klasifikasi =\n    row['Klasifikasi'] ||\n    row.klasifikasi ||\n    'Belum Diklasifikasi';\n\n  if (byKlasifikasi[klasifikasi] !== undefined) {\n    byKlasifikasi[klasifikasi]++;\n  } else {\n    byKlasifikasi['Belum Diklasifikasi']++;\n  }\n\n  // =========================\n  // AI RISK LEVEL\n  // =========================\n  const risk =\n    row['AI Risk Level'] ||\n    row.ai_risk_level ||\n    'Unknown';\n\n  if (byRiskLevel[risk] !== undefined) {\n    byRiskLevel[risk]++;\n  } else {\n    byRiskLevel.Unknown++;\n  }\n\n  // =========================\n  // AI ISO CONTROLS\n  // =========================\n  const isoControls =\n    row['AI ISO Controls'] ||\n    row.ai_iso_controls ||\n    '';\n\n  if (isoControls) {\n\n    const controls = isoControls\n      .split(',')\n      .map(c => c.trim())\n      .filter(Boolean);\n\n    for (const control of controls) {\n\n      if (!isoControlCounter[control]) {\n        isoControlCounter[control] = 0;\n      }\n\n      isoControlCounter[control]++;\n    }\n  }\n}\n\n// =========================\n// TOP ISO CONTROLS\n// =========================\nconst topControls = Object.entries(isoControlCounter)\n  .sort((a, b) => b[1] - a[1])\n  .slice(0, 5);\n\nconst topControlsText = topControls.length\n  ? topControls\n      .map(([control, count]) =>\n        `• ${control} (${count} aset)`\n      )\n      .join('\\n')\n  : 'Tidak ada data';\n\n// =========================\n// GENERATE LAPORAN\n// =========================\nconst laporan = `📊 *LAPORAN INVENTORY ASET SMKI*\n📅 Tanggal: ${today}\n\n*Ringkasan Inventory:*\n• Total Aset: ${total}\n• ✅ OK: ${ok}\n• ⏰ Due Soon: ${dueSoon}\n• ❌ Overdue: ${overdue}\n\n*Klasifikasi Aset:*\n• Confidential: ${byKlasifikasi.Confidential}\n• Restricted: ${byKlasifikasi.Restricted}\n• Internal: ${byKlasifikasi.Internal}\n• Public: ${byKlasifikasi.Public}\n• Belum Diklasifikasi: ${byKlasifikasi['Belum Diklasifikasi']}\n\n*AI Risk Analysis:*\n• Critical: ${byRiskLevel.Critical}\n• High: ${byRiskLevel.High}\n• Medium: ${byRiskLevel.Medium}\n• Low: ${byRiskLevel.Low}\n• Unknown: ${byRiskLevel.Unknown}\n\n*Top ISO 27001 Controls:*\n${topControlsText}\n\n_Laporan otomatis WF-01 Asset Management_`;\n\n// =========================\n// RETURN\n// =========================\nreturn [\n  {\n    json: {\n      laporan,\n\n      tanggal: today,\n\n      total,\n      overdue,\n      due_soon: dueSoon,\n      ok,\n\n      by_klasifikasi: byKlasifikasi,\n\n      by_risk_level: byRiskLevel,\n\n      top_iso_controls: topControls\n    }\n  }\n];"
      },
