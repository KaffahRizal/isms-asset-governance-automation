    {
      "parameters": {
        "jsCode": "const today = new Date();\nconst items = $input.all();\nconst result = [];\n\nfor (const item of items) {\n  const row = item.json;\n\n  // Hitung hari sejak review terakhir\n  const lastReview = row['Tanggal Review Terakhir']\n    ? new Date(row['Tanggal Review Terakhir'])\n    : new Date('2000-01-01');\n  const diffMs = today - lastReview;\n  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));\n\n  // Tentukan status review\n  let reviewStatus = 'OK';\n  let needsReminder = false;\n\n  if (diffDays >= 365) {\n    reviewStatus = 'OVERDUE';\n    needsReminder = true;\n  } else if (diffDays >= 330) {\n    reviewStatus = 'DUE_SOON';\n    needsReminder = true;\n  }\n\n  // Klasifikasi aset (jika belum ada)\n  const classification = row['Klasifikasi'] || 'Belum Diklasifikasi';\n\n  result.push({\n    json: {\n      ...row,\n      hari_sejak_review: diffDays,\n      review_status: reviewStatus,\n      needs_reminder: needsReminder,\n      klasifikasi: classification,\n      tanggal_cek: today.toISOString().split('T')[0]\n    }\n  });\n}\n\nreturn result;"
      },
